rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // allow anyone to read events and about collections 
    match /events/{document=**} {
      allow read: if true;
    }
    match /banners/{document=**} {
      allow read: if true;
      allow write: if true; 
    }
    match /content/{document=**} {
      allow read: if true;
    }
    match /exhibitors/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // allow authenticated users to read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // allow anyone to submit registrations/enquiries
    match /registrations/{document=**} {
      allow create: if true;
    }
    // allow anyone to submit enquiries
    match /enquiries/{document=**} {
      allow create: if true;
    }

    // allow anyone to register for events (old structure fallback)
    match /events/{eventId}/registrants_individual/{document=**} {
      allow create: if true;
    }
    match /events/{eventId}/registrants_school/{document=**} {
      allow create: if true;
    }

    // new nested structure: events/{year}/{eventCode}/{type}/registrants/{email}
    match /events/{year}/{eventCode}/{type}/registrants/{email} {
      allow create, update: if true;
    }
    
    // allow anyone to read/update the registration sequence counter
    match /counters/registrationSequence {
      allow read, write: if true;
    }

    match /likes/{likeId} {
      // Keys are bannerId_userId
      allow read: if true;
      allow create: if true; 
      allow delete: if true; 
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
